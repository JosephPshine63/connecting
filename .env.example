# Copy this file to .env and fill in strong values before deploying.
# .env is git-ignored and never committed.

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=connecting_db

# Keycloak
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Admin email — this account is never auto-deleted by the inactivity cleanup
ADMIN_EMAIL=your@email.com

# Cloudflare R2 (avatar storage) — create a bucket + an S3-compatible API token
# with Object Read & Write permissions scoped to that bucket. Enable the bucket's
# "Public Development URL" (or bind a custom domain) for R2_PUBLIC_BASE_URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
